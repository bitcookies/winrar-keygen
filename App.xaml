<Application x:Class="WinRarKeygenGui.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:WinRarKeygenGui"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <local:IntToBoolConverter x:Key="IntToBoolConverter" />
            <local:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
            <local:StringToVisibilityConverter x:Key="StringToVisConverter" />
            <local:StringToBoolConverter x:Key="StringToBoolConverter" />
            <local:InverseBoolConverter x:Key="InverseBoolConverter" />

            <!-- ============ Color Brushes matching HTML mockup (Light defaults, updated in code for Dark) ============ -->
            <SolidColorBrush x:Key="SettingsCardBg" Color="#08000000" />
            <SolidColorBrush x:Key="SettingsDividerBrush" Color="#0D000000" />
            <SolidColorBrush x:Key="SegmentedControlBg" Color="#0A000000" />
            <SolidColorBrush x:Key="SegmentedActiveBg" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="SegmentedHoverBg" Color="#0A000000" />
            <SolidColorBrush x:Key="InputBg" Color="#8CFFFFFF" />
            <SolidColorBrush x:Key="InputBorderBrush" Color="#14000000" />
            <SolidColorBrush x:Key="InputBottomBorderBrush" Color="#1A000000" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#A6FFFFFF" />
            <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#D9FFFFFF" />
            <SolidColorBrush x:Key="AccentBrush" Color="#C8661E" />
            <SolidColorBrush x:Key="AccentHoverBrush" Color="#B55B18" />
            <SolidColorBrush x:Key="OutputBoxBg" Color="#B3F9F9F9" />
            <SolidColorBrush x:Key="OutputBoxBorder" Color="#0F000000" />

            <!-- ============ Warning popup (floating tooltip-style bubble) ============ -->
            <SolidColorBrush x:Key="WarningForeground" Color="#B8860B" />
            <SolidColorBrush x:Key="WarningPopupBg" Color="#FFFFF8E1" />
            <SolidColorBrush x:Key="WarningPopupBorder" Color="#40B8860B" />

            <Style x:Key="WarningPopupBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource WarningPopupBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource WarningPopupBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="10,6" />
            </Style>

            <Style x:Key="WarningPopupTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{DynamicResource WarningForeground}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <!-- ============ Input TextBox with bottom-border shadow (mockup style) ============ -->
            <Style x:Key="InputBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource InputBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
                <Setter Property="BorderThickness" Value="1,1,1,2" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="MockupTextBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="11,7" />
                <Setter Property="FontSize" Value="13.5" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="CaretBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            </Style>

            <!-- Small input (used in Output row inside settings card) -->
            <Style x:Key="SmallInputBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource InputBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="SmallTextBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="CaretBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            </Style>

            <!-- ============ Small button (Browse) ============ -->
            <Style x:Key="SmallBtnStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="10,4"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============ Generate Button — solid accent blue ============ -->
            <Style x:Key="GenerateButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="0,9"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="Bd" Property="RenderTransformOrigin" Value="0.5,0.5" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============ Copy Button ============ -->
            <Style x:Key="CopyBtnStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="10,3"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============ Footer Button (settings gear, theme toggle) ============ -->
            <Style x:Key="FooterBtnStyle" TargetType="Button">
                <Setter Property="Width" Value="30" />
                <Setter Property="Height" Value="30" />
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============ Segmented Radio Button Style (Apple-like) ============ -->
            <Style x:Key="SegmentedRadioStyle" TargetType="RadioButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Padding" Value="8,5" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsChecked" Value="False" />
                                        <Condition Property="IsMouseOver" Value="True" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource SegmentedHoverBg}" />
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============ Pill Toggle Button (iOS-like switch) ============ -->
            <Style x:Key="PillToggleStyle" TargetType="ToggleButton">
                <Setter Property="Width" Value="44" />
                <Setter Property="Height" Value="24" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid>
                                <Border x:Name="Track"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        SnapsToDevicePixels="True" />
                                <Canvas Width="44" Height="24">
                                    <Ellipse x:Name="Thumb"
                                             Width="18" Height="18"
                                             Fill="White"
                                             Canvas.Left="3" Canvas.Top="3">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.2" Color="Black" />
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </Canvas>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}" />
                                    <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Thumb"
                                                                 Storyboard.TargetProperty="(Canvas.Left)"
                                                                 To="23" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="Thumb"
                                                                 Storyboard.TargetProperty="(Canvas.Left)"
                                                                 To="3" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsChecked" Value="True" />
                                        <Condition Property="IsMouseOver" Value="True" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                                    <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                                </MultiTrigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsChecked" Value="False" />
                                        <Condition Property="IsMouseOver" Value="True" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Track" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
